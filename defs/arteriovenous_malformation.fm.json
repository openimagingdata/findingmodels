{
  "oifm_id": "OIFM_OIDM_558398",
  "name": "arteriovenous malformation",
  "description": "A congenital vascular anomaly characterized by a direct arterial-to-venous connection without an intervening capillary bed, forming a nidus. It may be intracranial or occur in other tissues and can present with hemorrhage, seizures, or neurologic deficits; radiologic hallmark is a tangle of vessels with rapid arteriovenous shunting.",
  "synonyms": [
    "AVM",
    "arteriovenous malformation"
  ],
  "contributors": [
