{
  "oifm_id": "OIFM_MGB_616613",
  "name": "compression",
  "description": "A finding characterized by external pressure or mass causing reduction in size or volume of an adjacent structure, potentially altering contour or signal. In radiology, reported when an organ or tissue is pressed by surrounding structures or a device, such as vertebral canal compression, vessel compression, or tissue compression by edema or tumor.",
  "synonyms": [
    "compressive effect",
    "compression deformity",
    "compressed",
    "compression of",
    "compressive infarct"
  ],
  "tags": [
    "sub_finding_of:aberrant subclavian artery"
  ],
