{
  "oifm_id": "OIFM_MGB_650424",
  "name": "aneurysmal dilation",
  "description": "Aneurysmal dilation refers to the abnormal dilation of a blood vessel beyond its normal size, forming a sac-like expansion that increases risk of rupture. In radiology, this term is often used to describe a vessel that has expanded in caliber with a possible aneurysm.",
  "synonyms": [
    "aneurysmal dilation",
    "aneurysm dilation",
    "an13",
    "aneurysmal ectasia"
  ],
  "tags": [
    "sub_finding_of:aberrant subclavian artery"
  ],
