{
  "oifm_id": "OIFM_MGB_454597",
  "name": "associated anomalies",
  "description": "refers to concurrent or coexisting anomalies that may be linked to the primary finding or condition. In radiology, associated anomalies are non-radiographic or radiographic findings that occur with the primary abnormality and may influence diagnosis, prognosis, or management. Example: associated anomalies in the setting of a congenital anomaly may include cardiac, renal, or vertebral abnormalities as seen in systemic syndromes.",
  "synonyms": [
    "associated anomalies",
    "concomitant anomalies",
    "associated findings"
  ],
  "tags": [
    "sub_finding_of:aberrant subclavian artery"
