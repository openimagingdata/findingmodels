{
  "oifm_id": "OIFM_MGB_711422",
  "name": "aberrant subclavian artery",
  "description": "An anatomical variant in which a subclavian artery arises aberrantly from the aortic arch or its branches; may have a retroesophageal or other course and can cause compression or aneurysmal change.",
  "synonyms": [
    "aberrant right subclavian artery",
    "aberrant left subclavian artery",
    "arteria lusoria",
    "arteria lusoria anomaly"
  ],
