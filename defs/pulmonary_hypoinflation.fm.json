{
  "oifm_id": "OIFM_OIDM_378230",
  "name": "pulmonary hypoinflation",
  "description": "Reduced lung volume on chest radiograph, manifested by elevated diaphragms and crowded lung markings, which may be due to poor inspiratory effort, restrictive disease, or postoperative state.",
  "synonyms": [
    "decreased lung volumes",
    "reduced lung volumes",
    "small lung volumes",
    "hypoventilation",
    "poor inspiratory volume",
    "low lung volumes"
  ],
