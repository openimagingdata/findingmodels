{
  "oifm_id": "OIFM_OIDM_235579",
  "name": "traumatic pneumatocele",
  "description": "A thin-walled, air-filled cystic space within the lung parenchyma resulting from traumatic disruption, typically seen adjacent to or within areas of pulmonary contusion.",
  "synonyms": [
    "traumatic lung cyst",
    "post-traumatic pneumatocele"
  ],
