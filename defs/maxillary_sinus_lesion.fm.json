  "oifm_id": "OIFM_OIDM_479488",
  "name": "maxillary sinus lesion",
  "description": "An abnormal focal lesion within the maxillary sinus detected on imaging, with radiologic characterization describing size, location, density or signal characteristics, and effects on adjacent structures; the original phrasing 'maxillary sinus lesion' illustrates this general category.",
  "synonyms": [
    "maxillary sinus lesion",
    "lesion of the maxillary sinus",
    "maxillary sinus abnormality",
    "paranasal sinus lesion",
    "MS lesion"
