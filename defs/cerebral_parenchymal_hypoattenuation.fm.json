{
  "oifm_id": "OIFM_OIDM_017877",
  "name": "cerebral parenchymal hypoattenuation",
  "description": "Decreased attenuation within the brain parenchyma on CT imaging, indicating hypodensity of cerebral tissue. This finding is commonly associated with cerebral edema or acute infarction and may also reflect chronic gliosis or other hypodense processes; the original phrasing 'brain parenchymal hypoattenuation' illustrates the use case.",
  "synonyms": [
    "brain parenchymal hypoattenuation",
    "cerebral parenchymal hypoattenuation",
    "cerebral hypodensity",
    "hypoattenuation of cerebral parenchyma",
    "hypodense brain parenchyma"
  ],
