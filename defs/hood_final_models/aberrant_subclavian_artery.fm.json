{
  "oifm_id": "OIFM_MGB_693063",
  "name": "aberrant subclavian artery",
  "description": "Congenital variant in which a subclavian artery arises abnormally from the aortic arch or its branches, often coursing posterior to the esophagus; described by side of origin, course, compression effects, atherosclerosis, aneurysmal dilation, and other arterial anomalies.",
  "synonyms": [
    "aberrant subclavian",
    "arteria lusoria",
    "lusorian artery",
    "aberrant right subclavian",
    "aberrant left subclavian"
  ],
  "tags": [
    "vascular",
    "thoracic",
    "congenital",
    "arterial anomaly"
  ],
