  "oifm_id": "OIFM_MGB_464733",
  "name": "aberrant subclavian artery",
  "description": "An aortic arch branching anomaly in which one or both subclavian arteries arise anomalously (commonly arteria lusoria), typically coursing posterior to the esophagus or anterior to the trachea and potentially causing compressive symptoms or aneurysmal dilation.",
  "synonyms": [
    "arteria lusoria",
    "aberrant right subclavian artery",
    "aberrant left subclavian artery",
    "aberrant subclavian artery (arteria lusoria)",
