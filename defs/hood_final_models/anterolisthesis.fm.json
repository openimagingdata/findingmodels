{
  "oifm_id": "OIFM_MGB_751078",
  "name": "anterolisthesis",
  "description": "Anterior displacement (forward slippage) of one vertebral body relative to the one below; characterized by presence, temporal status, anatomic location, grade or percent translation, involved levels, and associated findings such as foraminal narrowing and disc degeneration.",
  "synonyms": [
    "anterior translation",
    "forward slippage",
    "anterior displacement"
  ],
  "tags": [
    "spine",
    "spondylolisthesis",
    "translation"
  ],
