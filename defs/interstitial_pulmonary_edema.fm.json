  "oifm_id": "OIFM_OIDM_651696",
  "name": "interstitial pulmonary edema",
  "description": "Fluid accumulation in the pulmonary interstitium on chest radiograph, manifesting as Kerley lines, peribronchial cuffing, and septal thickening, typically preceding alveolar edema.",
  "synonyms": [
    "interstitial edema",
    "pulmonary interstitial edema"
  ],
