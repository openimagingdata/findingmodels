{
  "oifm_id": "OIFM_OIDM_687433",
  "name": "burr hole",
  "description": "A burr hole is a surgically created opening in the calvarium for neurosurgical access or decompression. On imaging, it appears as a small, round skull defect with well-defined margins; postoperative changes may include surrounding bone remodeling.",
  "synonyms": [
    "burr hole",
    "burr holes",
    "surgical burr hole",
    "calvarial burr hole",
    "trephination site"
  ],
