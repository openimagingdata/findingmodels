{
  "oifm_id": "OIFM_OIDM_571942",
  "name": "arterial stenosis",
  "description": "Focal or diffuse narrowing of an artery causing luminal diameter reduction that may impair distal perfusion; typically characterized on imaging by degree of luminal narrowing, anatomic location, hemodynamic impact, and change over time.",
  "synonyms": [
    "artery stenosis",
    "arterial narrowing",
    "narrowing of an artery"
  ],
  "tags": [
    "vascular",
    "artery",
    "stenosis",
    "hemodynamics"
  ],
