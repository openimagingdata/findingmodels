{
  "oifm_id": "OIFM_OIDM_309190",
  "name": "soft tissue hematoma",
  "description": "Localized collection of blood within the soft tissues, usually resulting from trauma or vessel injury. It may present as a tender, expanding swelling; imaging demonstrates a well-circumscribed collection whose signal characteristics evolve with the age of the hematoma.",
  "synonyms": [
    "soft-tissue hematoma",
    "subcutaneous hematoma",
    "intramuscular hematoma",
    "muscle hematoma"
  ],
