{
  "oifm_id": "OIFM_OIDM_697155",
  "name": "transependymal cerebrospinal fluid flow",
  "description": "Transependymal cerebrospinal fluid flow describes CSF crossing the ependymal lining into the periventricular interstitium, typically reflecting elevated intracranial pressure such as hydrocephalus. The original term 'transependymal CSF flow' is used here as the example context for this finding.",
  "synonyms": [
    "transependymal CSF flow",
    "trans-ependymal CSF flow",
    "CSF transependymal flow",
    "transependymal flow"
  ],
