{
  "oifm_id": "OIFM_OIDM_671373",
  "name": "organized fluid collection",
  "description": "An organized fluid collection is a mature, encapsulated fluid collection with internal organization, septations or debris and a thickened wall. It may represent a chronic or organized collection such as a resolved or evolving abscess, hematoma, or seroma, depending on clinical context.",
  "synonyms": [
    "organized fluid collection",
    "encapsulated fluid collection",
    "organized effusion",
    "encysted fluid collection"
  ],
