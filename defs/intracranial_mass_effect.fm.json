{
  "oifm_id": "OIFM_OIDM_612864",
  "name": "intracranial mass effect",
  "description": "Displacement and compression of intracranial structures caused by a space-occupying lesion, leading to distortion of adjacent brain parenchyma. Radiographic signs include sulcal effacement, ventricular compression or enlargement, and midline shift with risk of herniation depending on lesion size and edema.",
  "synonyms": [
    "intracranial mass effect",
    "mass effect",
    "brain mass effect",
    "cerebral mass effect"
  ],
