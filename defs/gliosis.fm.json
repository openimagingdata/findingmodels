{
  "oifm_id": "OIFM_OIDM_359647",
  "name": "gliosis",
  "description": "Reactive proliferation of astrocytes resulting in glial scar formation following CNS injury or insult. Radiographically, gliosis presents as areas of increased signal on T2/FLAIR sequences corresponding to the site of injury and may correlate with prior infarct or trauma.",
  "synonyms": [
    "reactive gliosis",
    "gliotic change",
    "glial scar"
  ],
