{
  "oifm_id": "OIFM_OIDM_838821",
  "name": "pontine infarct",
  "description": "Ischemic infarction involving the pons, typically appearing as a focal area of hypoattenuation on CT. CT sensitivity for acute pontine infarcts is limited due to posterior fossa beam-hardening artifact, and MRI is often required for confirmation.",
  "synonyms": [
    "pontine infarction",
    "pons infarct",
    "pons infarction"
  ],
