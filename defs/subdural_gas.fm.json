{
  "oifm_id": "OIFM_OIDM_436864",
  "name": "subdural gas",
  "description": "Gas within the subdural space is an extra-axial gas collection between the dura and arachnoid membranes. It is most commonly seen post-trauma or post-surgical and may reflect residual subdural air; correlate with history of skull fracture, dural tear, or neurosurgical intervention.",
  "synonyms": [
    "subdural gas",
    "subdural air",
    "gas in subdural space"
  ],
