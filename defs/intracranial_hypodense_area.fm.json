{
  "oifm_id": "OIFM_OIDM_178692",
  "name": "intracranial hypodense area",
  "description": "Regions of decreased attenuation within the intracranial contents on CT imaging; may reflect edema, acute or chronic ischemia with encephalomalacia, or chronic gliosis. Correlate with MRI and clinical context for etiology and acuity.",
  "synonyms": [
    "intracranial hypodensity",
    "intracranial hypodensity",
    "intracranial hypodense region",
    "low attenuation within intracranial contents",
    "low attenuation intracranial region",
    "hypodense region of brain",
    "hypodense area in brain"
  ],
  "tags": [
    "brain",
    "ct",
    "intracranial",
    "hypodensity",
    "head ct"
  ],
  "anatomic_locations": null,
