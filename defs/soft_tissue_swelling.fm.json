{
  "oifm_id": "OIFM_OIDM_962320",
  "name": "soft tissue swelling",
  "description": "Localized or diffuse soft tissue swelling is a non-specific radiologic finding that may reflect edema, inflammation, contusion, or hemorrhage. Correlate with clinical history and examination for possible underlying fracture or other soft-tissue injury.",
  "synonyms": [
    "soft tissue swelling",
    "soft-tissue swelling",
    "soft tissue edema",
    "edematous soft tissues",
    "subcutaneous edema"
  ],
