{
  "oifm_id": "OIFM_OIDM_220685",
  "name": "subclavian artery stenosis",
  "description": "Narrowing of the subclavian artery, typically proximal, with potential hemodynamic significance that can reduce perfusion to the ipsilateral upper extremity and may be associated with retrograde vertebral artery flow (subclavian steal). In practice, this finding may be reported exactly as 'subclavian artery stenosis' in imaging reports.",
  "synonyms": [
    "subclavian artery stenosis",
    "stenosis of the subclavian artery",
    "subclavian arterial stenosis",
    "stenosis of subclavian artery",
    "SAS",
    "left subclavian artery stenosis",
    "right subclavian artery stenosis"
  ],
