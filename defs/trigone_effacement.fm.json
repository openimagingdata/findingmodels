{
  "oifm_id": "OIFM_OIDM_647625",
  "name": "trigone effacement",
  "description": "Loss of normal delineation of the bladder trigone on imaging. The original term 'trigone effacement' exemplifies this loss of trigone contour and may reflect bladder wall edema, inflammatory change, or adjacent mass effect.",
  "synonyms": [
    "trigone effacement",
    "trigonal effacement",
    "loss of trigone delineation",
    "obliteration of trigone contour",
    "loss of bladder trigone definition",
    "trigone contour effacement"
  ],
