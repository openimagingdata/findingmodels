{
  "oifm_id": "OIFM_MGB_174876",
  "name": "aberrant subclavian artery",
  "description": "Congenital aortic arch branching anomaly in which a subclavian artery arises abnormally from the aortic arch (or brachiocephalic/innominate artery) and follows an atypical course, often posterior to the esophagus (retroesophageal). This variant may be incidental or associated with compressive symptoms or aneurysmal change.",
  "synonyms": [
    "arteria lusoria",
    "aberrant right subclavian artery",
    "aberrant left subclavian artery",
    "arteria lusoria syndrome"
  ],
  "tags": [
    "ct",
    "chest",
    "vascular",
    "aortic arch",
    "congenital anomaly",
    "subclavian artery"
  ],
