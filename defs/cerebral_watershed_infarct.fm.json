{
  "oifm_id": "OIFM_OIDM_832726",
  "name": "cerebral watershed infarct",
  "description": "Ischemic infarction occurring in the vascular border zones between major cerebral arterial territories, typically resulting from systemic hypoperfusion or hemodynamic compromise. On CT, these appear as hypoattenuating regions in the internal or cortical watershed zones, often bilateral.",
  "synonyms": [
    "watershed infarct",
    "border zone infarct",
    "borderzone infarct",
    "watershed stroke"
  ],
  "tags": [
    "head",
    "CT"
  ],
