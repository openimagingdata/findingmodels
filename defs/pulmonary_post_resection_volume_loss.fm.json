{
  "oifm_id": "OIFM_OIDM_392629",
  "name": "pulmonary post-resection volume loss",
  "description": "Reduction in lung volume following surgical resection (lobectomy, segmentectomy, or wedge resection), visible as ipsilateral volume loss with compensatory changes on chest radiograph.",
