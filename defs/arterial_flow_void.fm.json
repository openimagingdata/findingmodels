{
  "oifm_id": "OIFM_OIDM_352299",
  "name": "arterial flow void",
  "description": "Arterial flow void refers to the loss of signal within arteries on MRI sequences caused by rapid arterial blood flow, reflecting high-velocity flow in patent vessels. An 'arterial flow void abnormality' describes an atypical or altered flow-void appearance and may indicate vascular pathology such as stenosis or occlusion.",
  "synonyms": [
    "arterial flow void abnormality",
    "arterial signal void",
    "flow void in arteries"
  ],
