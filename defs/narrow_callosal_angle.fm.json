{
  "oifm_id": "OIFM_OIDM_164708",
  "name": "narrow callosal angle",
  "description": "A radiologic finding defined by a reduced angle between the bodies of the lateral ventricles at the level of the corpus callosum on coronal CT or MR images, often assessed to evaluate ventriculomegaly. The term 'narrow callosal angle' may be used to describe this appearance.",
  "synonyms": [
    "narrowing of the callosal angle",
    "callosal angle narrowing",
    "narrow callosal angle sign",
    "callosal angle sign"
  ],
