{
  "oifm_id": "OIFM_OIDM_413880",
  "name": "encephalomalacia",
  "description": "Encephalomalacia denotes focal or diffuse loss of brain parenchyma with gliosis, usually following prior infarction, hypoxic-ischemic injury, infection, or inflammatory insult; radiology reports may also refer to it as postinfarct brain softening. Imaging demonstrates tissue loss with ex vacuo ventricular enlargement and sulcal widening in the affected territory, which may appear hypodense on CT or show gliotic changes on MRI.",
  "synonyms": [
    "encephalomalacia",
    "brain softening",
    "cerebral softening",
    "postinfarct encephalomalacia",
    "postinfarct brain softening"
  ],
