{
  "oifm_id": "OIFM_OIDM_907498",
  "name": "hiatal hernia",
  "description": "Herniation of abdominal contents (typically stomach) through the esophageal hiatus of the diaphragm, visible on chest radiograph as a retrocardiac soft tissue density often with an air-fluid level.",
  "synonyms": [
    "hiatus hernia",
    "diaphragmatic hiatal hernia"
  ],
