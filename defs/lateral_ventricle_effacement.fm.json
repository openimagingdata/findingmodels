{
  "oifm_id": "OIFM_OIDM_372233",
  "name": "lateral ventricle effacement",
  "description": "Lateral ventricle effacement refers to the compression or obliteration of the normal lateral ventricular margins due to adjacent mass effect, edema, or space-occupying pathology, resulting in reduced ventricular CSF spaces. Original phrasing: 'lateral ventricle effacement'.",
  "synonyms": [
    "lateral ventricle effacement",
    "effacement of the lateral ventricles",
    "ventricular effacement",
    "LVE"
  ],
