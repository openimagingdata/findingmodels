{
  "oifm_id": "OIFM_OIDM_133070",
  "name": "pulmonary hyperinflation",
  "description": "Increased lung volume on chest radiograph, manifesting as flattened diaphragms, increased AP diameter, widened intercostal spaces, and increased retrosternal clear space. Commonly seen in COPD and asthma.",
  "synonyms": [
    "hyperinflated lungs",
    "hyperinflation of lungs",
    "lung hyperinflation",
    "overinflation",
    "hyperexpanded lungs",
    "hyperinflation"
  ],
