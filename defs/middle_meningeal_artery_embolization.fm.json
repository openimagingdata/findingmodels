{
  "oifm_id": "OIFM_OIDM_723535",
  "name": "middle meningeal artery embolization",
  "description": "A minimally invasive endovascular procedure in which embolic material is delivered through a catheter to occlude the middle meningeal artery, reducing dural blood flow. It is performed to manage or reduce recurrence of chronic subdural hematoma and other dural vascular pathologies.",
  "synonyms": [
    "MMA embolization",
    "embolization of the middle meningeal artery"
  ],
