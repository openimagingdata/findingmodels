{
  "oifm_id": "OIFM_OIDM_226740",
  "name": "external carotid artery stenosis",
  "description": "External carotid artery stenosis refers to narrowing of the external carotid artery seen on imaging, most commonly due to atherosclerotic plaque. Report should include the degree of luminal stenosis and any associated wall irregularity or post-stenotic flow changes.",
  "synonyms": [
    "external carotid stenosis",
    "ECA stenosis",
    "stenosis of the external carotid artery",
    "external carotid artery narrowing",
    "ECA narrowing"
  ],
