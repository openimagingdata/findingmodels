  "oifm_id": "OIFM_OIDM_220882",
  "name": "cervical lymphadenopathy",
  "description": "Enlargement of one or more cervical lymph nodes. It may be unilateral or bilateral and can reflect infectious, inflammatory, or neoplastic processes.",
  "synonyms": [
    "cervical LN enlargement",
    "enlarged cervical lymph nodes",
    "cervical lymph node enlargement",
    "cervical lymphadenopathy"
