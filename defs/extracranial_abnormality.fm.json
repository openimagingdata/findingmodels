{
  "oifm_id": "OIFM_OIDM_957490",
  "name": "extracranial abnormality",
  "description": "Non-specific finding referring to an abnormality located outside the cranium; definitive characterization requires correlation with imaging modality, location, size, and morphology. The phrase 'extracranial abnormality' serves as a generic descriptor and may refer to lesions in structures such as the scalp, neck, or chest outside the skull.",
  "synonyms": [
    "extracranial abnormality",
    "extracranial lesion",
    "extra-cranial abnormality",
    "outside-cranium abnormality"
  ],
