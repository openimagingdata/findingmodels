{
  "oifm_id": "OIFM_OIDM_990793",
  "name": "white matter hypodensity",
  "description": "Regions of decreased attenuation in the cerebral white matter on CT or decreased signal on MRI. These changes can reflect chronic small vessel ischemic disease, demyelination, edema, or other pathology; the original detailed phrasing 'white matter hypodensity' exemplifies this finding.",
  "synonyms": [
    "white matter hypoattenuation",
    "hypodense white matter",
    "white matter low attenuation",
    "leukoaraiosis"
  ],
