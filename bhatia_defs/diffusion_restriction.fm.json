{
  "oifm_id": "OIFM_OIDM_146917",
  "name": "diffusion restriction",
  "description": "Diffusion restriction refers to reduced diffusion of water molecules on diffusion-weighted MRI, typically seen as hyperintensity on DWI with corresponding hypointensity on the ADC map. This pattern is most consistent with cytotoxic edema and is commonly seen in acute ischemic stroke, though it may be encountered with other processes such as abscess or highly cellular lesions.",
  "synonyms": [
    "restricted diffusion",
    "diffusion restriction on diffusion-weighted imaging",
    "diffusion restriction on DWI"
  ],
